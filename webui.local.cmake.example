# Per-machine WebUI source override — copy to `webui.local.cmake` (gitignored).
#
# PitchFold's WebUI source lives in the music-suite monorepo (apps/pitchfold),
# shared with the standalone webapp. CMake defaults to a sibling checkout:
#   ${CMAKE_SOURCE_DIR}/../music-suite/apps/pitchfold
#
# If your music-suite checkout is elsewhere, point PITCHFOLD_WEBUI_DIR at its
# apps/pitchfold directory here. The monorepo must be `npm install`ed so esbuild
# and react resolve from its hoisted node_modules.
set(PITCHFOLD_WEBUI_DIR "/path/to/music-suite/apps/pitchfold" CACHE PATH "" FORCE)
